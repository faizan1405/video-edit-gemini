OPENAI_API_KEY=your_openai_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here
MAX_UPLOAD_MB=500

# ── Transcription models ────────────────────────────────────────────────────────
# Primary transcription model — gpt-4o-transcribe gives far better word accuracy
# than the legacy whisper-1 model, especially for Hinglish / accented speech.
TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Automatic fallback if the primary model call fails (e.g. quota / outage).
TRANSCRIPTION_FALLBACK_MODEL=gpt-4o-mini-transcribe
# Legacy key still accepted for backward compatibility:
# OPENAI_TRANSCRIPTION_MODEL=whisper-1

# ── Planning / text models ──────────────────────────────────────────────────────
# Model used ONLY for B-roll moment selection and Pexels query generation.
# Do NOT use a transcription model here.
BROLL_PLANNING_MODEL=gpt-4.1
# Model used for minimal transcript cleanup (homophone correction, punctuation).
OPENAI_TEXT_MODEL=gpt-4o
# Safety switch — must stay false to prevent GPT from being used for transcription.
USE_GPT_FOR_DIRECT_TRANSCRIPTION=false

# ── Caption settings ────────────────────────────────────────────────────────────
ENABLE_CAPTION_CHUNKING=true
# Hard cap on words per caption segment (3-6 is ideal for Reels/Shorts).
MAX_WORDS_PER_CAPTION=6
# Minimum time a caption stays visible in milliseconds.
# 1200 ms prevents flash-and-vanish for fast speakers.
MIN_CAPTION_DURATION_MS=1200
# Maximum time a single caption may linger in milliseconds.
# 4000 ms prevents frozen captions from stale timing.
MAX_CAPTION_DURATION_MS=4000

# ── B-roll count and confidence ─────────────────────────────────────────────────
# Minimum number of B-roll slots (enforced when enough relevant moments exist).
MIN_BROLL_COUNT=7
# Maximum number of B-roll slots per video.
MAX_BROLL_COUNT=14
# Only use B-roll moments where the planning model's confidence >= this value.
# Range 0.0–1.0. Higher = fewer but more relevant B-roll slots.
BROLL_CONFIDENCE_THRESHOLD=0.75
DEFAULT_BROLL_PROVIDER=pexels
ENABLE_BROLL_ANIMATION=true

# ── B-roll transition animation ─────────────────────────────────────────────────
# Type: "fade" (smooth fade in/out) or "none" (hard cut, original behaviour)
BROLL_TRANSITION_TYPE=fade
# Entry / exit fade duration in milliseconds (200–400 ms is ideal for Reels/Shorts)
BROLL_FADE_IN_MS=300
BROLL_FADE_OUT_MS=300
# Zoom applied to image B-roll before center-crop (1.0 = off, 1.04 = subtle 4% zoom)
BROLL_ZOOM_STRENGTH=1.04

# ── B-roll animation preset system ─────────────────────────────────────────────
# Set to "false" to disable preset rotation and use a fixed animation for every segment
BROLL_ANIMATION_RANDOMIZE=true
# Minimum segments between repeating the same preset (1 = no two in a row)
BROLL_ANIMATION_MAX_REPEAT=1
# Zoom scale for the "scale-fade" preset (subtle punch-in; 1.06 = 6% overcrop)
BROLL_SCALE_FADE_STRENGTH=1.06
# Zoom scale for ken burns directional-crop presets (1.08 = 8% overcrop, offset crop)
BROLL_KENBURNS_STRENGTH=1.08
# Duration of slide-in motion for slide-up / slide-left / slide-right presets (seconds)
BROLL_SLIDE_ENTRY_DURATION=0.35
